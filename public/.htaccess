# 0. PASSENGER CONFIGURATION (Generated by DirectAdmin Logic)
PassengerAppRoot "/home/srv77673/domains/inlexistudio.com/cms-app"
PassengerBaseURI "/app"
PassengerNodejs "/home/srv77673/nodevenv/domains/inlexistudio.com/cms-app/22/bin/node"
PassengerAppType node
PassengerStartupFile app.js

RewriteEngine On
RewriteBase /

# 1. PASSENGER BACKEND (Redundant but safe)
# Do not rewrite /app requests. Let Passenger handle them.
RewriteRule ^app - [L]

# 2. TRAILING SLASH ENFORCEMENT
# If it's a directory but missing slash, redirect.
# This helps Apache find the index.html via DirectoryIndex.
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.*[^/])$ /$1/ [R=301,L]

# 3. DIRECTORY INDEX
# Ensure Apache looks for index.html (standard behavior, but being explicit helps)
DirectoryIndex index.html

# 3.1 CACHE CONTROL
# HTML should always revalidate so production deploys are visible immediately.
SetEnvIfNoCase Request_URI "^/_astro/" IS_ASTRO_ASSET=1

<IfModule mod_headers.c>
	<FilesMatch "\.(html?)$">
		Header set Cache-Control "no-cache, max-age=0, must-revalidate"
	</FilesMatch>

	Header set Cache-Control "public, max-age=31536000, immutable" env=IS_ASTRO_ASSET
</IfModule>

# 4. STATIC ASSETS
# Let Astro bundles and other static assets pass through untouched.
RewriteRule ^_astro/ - [L]
RewriteRule ^.*\.(?:css|js|mjs|json|map|svg|webp|png|jpe?g|gif|ico|woff2?|ttf)$ - [L,NC]

# 5. STATIC PAGE RESOLUTION
# Resolve clean URLs like /pricing or /pricing/ to their generated index.html files.
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.+?)/?$ /$1/index.html [L]

# 6. STANDARD FILE SERVING
# If file exists, serve it.
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 7. SPA / 404 FALLBACK
# If request is not a file and not a directory, show 404 or index.html
# Since this is a static site with subpages, we prefer 404 for missing pages
# rather than redirecting everything to home (which confuses invalid links).
ErrorDocument 404 /404.html
