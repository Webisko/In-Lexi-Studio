---
import Layout from '../layouts/Layout.astro';
import type { Page } from '../lib/api';
import {
  getGalleries,
  getMediaFiles,
  getPage,
  getPages,
  getSettings,
  getTestimonials,
} from '../lib/api';
import { PageContent } from '../components/PageContent';

function createFallbackPage(slug: string): Page {
  return {
    id: 0,
    slug,
    title: slug
      .split('-')
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join(' '),
    content: '',
  };
}

export async function getStaticPaths() {
  const fallbackDynamicPages = [
    'about',
    'approach',
    'portfolio',
    'wedding-photography',
    'portrait-photography',
    'product-photography',
  ].map((slug) => ({
    id: 0,
    slug,
    title: slug
      .split('-')
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join(' '),
    content: '',
  }));
  const reservedStaticSlugs = new Set([
    '',
    '/',
    'home',
    'contact',
    'pricing',
    'privacy-policy',
    '404',
  ]);
  const pages = await getPages();
  const sourcePages = Array.isArray(pages) && pages.length ? pages : fallbackDynamicPages;
  console.log('Re-generating paths with data from API:', sourcePages.length, 'pages found.');
  return sourcePages
    .filter((p) => p.slug && !reservedStaticSlugs.has(String(p.slug).trim().toLowerCase()))
    .map((page) => ({
      params: { slug: page.slug },
      props: { page },
    }));
}

const routeSlug = String(Astro.params.slug || '').trim();
const pageFromProps = (Astro.props.page as Page | null) || null;
const fetchedPage = routeSlug ? await getPage(routeSlug) : null;
const page = fetchedPage || pageFromProps || (routeSlug ? createFallbackPage(routeSlug) : null);

const settings = await getSettings();
const galleries = await getGalleries();
const testimonials = await getTestimonials();
const mediaFiles = await getMediaFiles();

if (!page?.slug) {
  return Astro.redirect('/404');
}
---

<Layout
  title={page.meta_title || page.title || settings?.meta_title || settings?.site_name}
  description={page.meta_description || settings?.meta_description}
  seoImage={page.seo_image || page.hero_image}
  settings={settings}
>
  <PageContent
    client:load
    initialPage={page}
    initialGalleries={galleries || []}
    initialTestimonials={testimonials || []}
    initialMediaFiles={mediaFiles || []}
  />
</Layout>
