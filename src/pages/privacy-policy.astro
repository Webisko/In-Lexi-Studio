---
import Layout from '../layouts/Layout.astro';
import { getSettings, getPage } from '../lib/api';

const settings = await getSettings();
const page = await getPage('privacy-policy');
---

<Layout
  title={page?.meta_title || page?.title || 'Privacy Policy'}
  description={page?.meta_description || 'Privacy Policy - InLexi Studio'}
  seoImage={page?.seo_image}
  settings={settings}
>
  <div class="container mx-auto px-6 py-24 md:py-32">
    <div class="mx-auto max-w-4xl">
      <h1 class="mb-2 text-center font-display text-4xl text-white md:text-5xl">
        {page?.title || 'Privacy Policy'}
      </h1>
      <p class="mb-12 text-center text-sm text-gray-400">
        In Lexi Studio | Photography Services &nbsp;·&nbsp; Last updated: 1 March 2026
      </p>

      <p class="mb-12 text-lg leading-relaxed text-gray-300">
        This Privacy Policy explains how In Lexi Studio collects, uses, stores, and protects your
        personal data. It complies with the UK General Data Protection Regulation (UK GDPR) and the
        Data Protection Act 2018, and is also designed to meet the requirements of the EU General
        Data Protection Regulation (EU GDPR) for clients based in European Union member states.
      </p>

      <div class="space-y-10 text-gray-300">
        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">1. Data Controller</h2>
          <p class="mb-3">The data controller responsible for your personal data is:</p>
          <ul class="mb-4 space-y-1 pl-5">
            <li class="list-disc">Name: Alex Leszczyński</li>
            <li class="list-disc">Trading as: In Lexi Studio</li>
            <li class="list-disc">
              Address: 2 Haughview Terrace, G5 0LN, Glasgow, Scotland, United Kingdom
            </li>
            <li class="list-disc">
              Email: <a
                href="mailto:info@inlexistudio.com"
                class="text-gold underline hover:text-white">info@inlexistudio.com</a
              >
            </li>
            <li class="list-disc">Phone: +44 79 6651 6199</li>
            <li class="list-disc">Website: www.inlexistudio.com</li>
            <li class="list-disc">
              ICO Registration Number: <em
                >[to be confirmed – register at ico.org.uk if not yet registered]</em
              >
            </li>
          </ul>
          <p>
            For clients based in the European Union, Alex Leszczyński acts as the data controller
            under Article 4(7) of the EU GDPR. As the processing of EU residents' personal data is
            only occasional and incidental to our primary UK-based practice, we are not required to
            appoint a formal EU representative under Article 27 of the EU GDPR.
          </p>
        </section>

        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">2. What Personal Data We Collect</h2>
          <p class="mb-3">We may collect and process the following categories of personal data:</p>

          <p class="mb-2 font-semibold text-white">2.1 Information You Provide Directly</p>
          <ul class="mb-4 space-y-1 pl-5">
            <li class="list-disc">Full name</li>
            <li class="list-disc">Email address</li>
            <li class="list-disc">Phone number</li>
            <li class="list-disc">
              Postal address (where required for service delivery or invoicing)
            </li>
            <li class="list-disc">Details about your photography project, event, or booking</li>
            <li class="list-disc">
              Payment and billing information (processed securely via third-party payment providers)
            </li>
            <li class="list-disc">
              Any other information you provide via contact forms, email, or in person
            </li>
          </ul>

          <p class="mb-2 font-semibold text-white">2.2 Information Collected Automatically</p>
          <ul class="mb-4 space-y-1 pl-5">
            <li class="list-disc">IP address and browser type (via website analytics)</li>
            <li class="list-disc">Pages visited and time spent on the website</li>
            <li class="list-disc">Cookies and similar tracking technologies (see Section 11)</li>
          </ul>

          <p class="mb-2 font-semibold text-white">2.3 Special Categories of Data</p>
          <p>
            We do not intentionally collect special category data (e.g. health information,
            ethnicity). However, photographs taken during a session may incidentally capture such
            characteristics. We rely on your explicit consent for any processing of images that may
            contain sensitive characteristics.
          </p>
        </section>

        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">3. How We Use Your Personal Data</h2>
          <p class="mb-3">We use your personal data for the following purposes:</p>
          <ul class="space-y-1 pl-5">
            <li class="list-disc">
              To respond to your enquiries and communicate with you about your booking
            </li>
            <li class="list-disc">To provide photography services as agreed under contract</li>
            <li class="list-disc">To issue invoices and process payments</li>
            <li class="list-disc">To deliver photographs and associated products to you</li>
            <li class="list-disc">To fulfil our legal and contractual obligations</li>
            <li class="list-disc">
              To send you marketing communications (only where you have given consent or we have a
              legitimate interest and you have not opted out)
            </li>
            <li class="list-disc">To improve our website and services</li>
            <li class="list-disc">
              To comply with legal obligations, including tax and accounting requirements
            </li>
          </ul>
        </section>

        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">4. Legal Basis for Processing</h2>
          <p class="mb-3">
            Under UK GDPR (and EU GDPR where applicable), we rely on the following legal bases:
          </p>
          <ul class="space-y-3 pl-5">
            <li class="list-disc">
              <span class="font-semibold text-white">Contract (Article 6(1)(b)):</span> Processing is
              necessary to fulfil a contract with you, or to take steps before entering into a contract.
            </li>
            <li class="list-disc">
              <span class="font-semibold text-white">Legal obligation (Article 6(1)(c)):</span> Processing
              is necessary to comply with UK law (e.g. tax records, HMRC requirements).
            </li>
            <li class="list-disc">
              <span class="font-semibold text-white">Legitimate interests (Article 6(1)(f)):</span> Processing
              is necessary for our legitimate business interests, such as marketing our services to existing
              clients, improving our website, and protecting our business — provided these interests are
              not overridden by your rights.
            </li>
            <li class="list-disc">
              <span class="font-semibold text-white">Consent (Article 6(1)(a)):</span> Where we rely on
              consent (e.g. sharing images on social media or our portfolio, or sending marketing emails
              to new contacts), you may withdraw your consent at any time by contacting us.
            </li>
          </ul>
        </section>

        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">5. Photographs and Image Rights</h2>
          <p class="mb-3">
            Any photographs taken during a session are subject to the terms of our contract with
            you. We may wish to use images for portfolio, marketing, or social media purposes. We
            will only do so:
          </p>
          <ul class="mb-4 space-y-1 pl-5">
            <li class="list-disc">With your explicit written consent, or</li>
            <li class="list-disc">
              Where the images do not identify individuals (e.g. landscape, architectural
              photography)
            </li>
          </ul>
          <p>
            You may withdraw consent for the use of your images at any time by contacting us at <a
              href="mailto:info@inlexistudio.com"
              class="text-gold underline hover:text-white">info@inlexistudio.com</a
            >. Withdrawal of consent does not affect the lawfulness of processing before withdrawal.
          </p>
        </section>

        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">6. Data Sharing and Third Parties</h2>
          <p class="mb-3">
            We do not sell your personal data. We may share your data with the following trusted
            third parties, only to the extent necessary:
          </p>
          <ul class="mb-4 space-y-1 pl-5">
            <li class="list-disc">
              Payment processors (e.g. Stripe, PayPal, bank transfer) — for invoicing and payment
              collection
            </li>
            <li class="list-disc">
              Cloud storage providers (e.g. Google Drive, Dropbox, or similar) — for secure file
              storage and delivery of photographs
            </li>
            <li class="list-disc">Email service providers — for communication and marketing</li>
            <li class="list-disc">
              Website hosting and analytics providers — for maintaining and improving our website
            </li>
          </ul>
          <p class="mb-4">
            All third-party service providers are required to handle your data securely and in
            accordance with applicable data protection law.
          </p>

          <p class="mb-2 font-semibold text-white">6.1 International Transfers</p>
          <p class="mb-2">
            Where we transfer personal data outside the UK or EEA (e.g. to cloud services based in
            the United States), we ensure appropriate safeguards are in place, such as:
          </p>
          <ul class="space-y-1 pl-5">
            <li class="list-disc">UK adequacy regulations or EU adequacy decisions</li>
            <li class="list-disc">
              Standard Contractual Clauses (SCCs) approved by the ICO or European Commission
            </li>
            <li class="list-disc">Other appropriate transfer mechanisms under UK GDPR / EU GDPR</li>
          </ul>
        </section>

        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">7. Data Retention</h2>
          <p class="mb-4">
            We retain your personal data only for as long as necessary for the purposes set out in
            this policy, or as required by law. Our standard retention periods are:
          </p>
          <div class="overflow-x-auto rounded-lg border border-white/10">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-white/10 bg-white/5">
                  <th class="px-4 py-3 text-left font-semibold text-gold">Type of Data</th>
                  <th class="px-4 py-3 text-left font-semibold text-gold">Retention Period</th>
                  <th class="px-4 py-3 text-left font-semibold text-gold">Reason</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/10">
                <tr class="hover:bg-white/5">
                  <td class="px-4 py-3">Client contact details</td>
                  <td class="px-4 py-3">6 years after last contact</td>
                  <td class="px-4 py-3 text-gray-400">Limitation period for legal claims (UK)</td>
                </tr>
                <tr class="hover:bg-white/5">
                  <td class="px-4 py-3">Financial and invoicing records</td>
                  <td class="px-4 py-3">7 years</td>
                  <td class="px-4 py-3 text-gray-400">HMRC requirement under UK tax law</td>
                </tr>
                <tr class="hover:bg-white/5">
                  <td class="px-4 py-3">Photographs (with consent for portfolio use)</td>
                  <td class="px-4 py-3">Until consent withdrawn</td>
                  <td class="px-4 py-3 text-gray-400">Consent-based processing</td>
                </tr>
                <tr class="hover:bg-white/5">
                  <td class="px-4 py-3">Marketing consent records</td>
                  <td class="px-4 py-3">Until consent withdrawn</td>
                  <td class="px-4 py-3 text-gray-400">UK GDPR consent requirements</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">8. Your Rights</h2>
          <p class="mb-3">
            Under UK GDPR (and EU GDPR for EU-based individuals), you have the following rights:
          </p>
          <ul class="mb-4 space-y-2 pl-5">
            <li class="list-disc">
              <span class="font-semibold text-white">Right of access:</span> You may request a copy of
              the personal data we hold about you (Subject Access Request).
            </li>
            <li class="list-disc">
              <span class="font-semibold text-white">Right to rectification:</span> You may ask us to
              correct inaccurate or incomplete data.
            </li>
            <li class="list-disc">
              <span class="font-semibold text-white">Right to erasure:</span> You may ask us to delete
              your personal data where there is no compelling reason to continue processing it.
            </li>
            <li class="list-disc">
              <span class="font-semibold text-white">Right to restrict processing:</span> You may ask
              us to limit how we use your data in certain circumstances.
            </li>
            <li class="list-disc">
              <span class="font-semibold text-white">Right to data portability:</span> You may request
              a copy of your data in a structured, machine-readable format.
            </li>
            <li class="list-disc">
              <span class="font-semibold text-white">Right to object:</span> You may object to processing
              based on legitimate interests or for direct marketing.
            </li>
            <li class="list-disc">
              <span class="font-semibold text-white">Right to withdraw consent:</span> Where processing
              is based on consent, you may withdraw it at any time without affecting the lawfulness of
              prior processing.
            </li>
          </ul>
          <p>
            To exercise any of these rights, please contact us at <a
              href="mailto:info@inlexistudio.com"
              class="text-gold underline hover:text-white">info@inlexistudio.com</a
            > or <a href="tel:+447966516199" class="text-gold underline hover:text-white"
              >+44 79 6651 6199</a
            >. We will respond within one calendar month of receiving your request.
          </p>
        </section>

        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">9. Right to Complain</h2>

          <p class="mb-2 font-semibold text-white">9.1 UK Clients</p>
          <p class="mb-3">
            If you are based in the UK and believe we have not handled your personal data correctly,
            you have the right to complain to the Information Commissioner's Office (ICO):
          </p>
          <ul class="mb-5 space-y-1 pl-5">
            <li class="list-disc">
              Website: <a
                href="https://www.ico.org.uk"
                target="_blank"
                class="text-gold underline hover:text-white">www.ico.org.uk</a
              >
            </li>
            <li class="list-disc">Phone: 0303 123 1113</li>
            <li class="list-disc">
              Address: Information Commissioner's Office, Wycliffe House, Water Lane, Wilmslow,
              Cheshire, SK9 5AF
            </li>
          </ul>

          <p class="mb-2 font-semibold text-white">9.2 EU Clients</p>
          <p>
            If you are based in the EU, you may complain to the data protection supervisory
            authority in your country of residence or place of work. Contact details for EU
            supervisory authorities are available at <a
              href="https://www.edpb.europa.eu"
              target="_blank"
              class="text-gold underline hover:text-white">www.edpb.europa.eu</a
            >.
          </p>
        </section>

        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">10. Data Security</h2>
          <p class="mb-3">
            We take appropriate technical and organisational measures to protect your personal data
            against unauthorised access, loss, destruction, or alteration. These measures include:
          </p>
          <ul class="mb-4 space-y-1 pl-5">
            <li class="list-disc">Secure and encrypted storage of digital files</li>
            <li class="list-disc">Password-protected devices and accounts</li>
            <li class="list-disc">Restricted access to personal data on a need-to-know basis</li>
            <li class="list-disc">
              Use of reputable third-party service providers with their own security measures
            </li>
          </ul>
          <p>
            In the event of a personal data breach that is likely to result in a risk to your rights
            and freedoms, we will notify the ICO within 72 hours and inform you without undue delay,
            as required by UK GDPR (and EU GDPR where applicable). Please report any suspected data
            breach to <a
              href="mailto:info@inlexistudio.com"
              class="text-gold underline hover:text-white">info@inlexistudio.com</a
            >.
          </p>
        </section>

        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">11. Cookies</h2>
          <p class="mb-3">
            Our website (www.inlexistudio.com) uses only technically essential cookies that are
            strictly necessary for the website to function. We do not use third-party tracking,
            advertising, or analytics cookies that require user consent under PECR (Privacy and
            Electronic Communications Regulations) or the EU ePrivacy Directive.
          </p>
          <p class="mb-3">
            Website analytics are performed using a privacy-focused, cookieless solution hosted
            locally on our server. No data is shared with third-party analytics providers, and no
            personally identifiable information is collected through our analytics.
          </p>
          <p>
            Because we only use essential cookies, we are not required to display a cookie consent
            banner under PECR or the EU ePrivacy Directive. If this changes in the future, this
            policy will be updated accordingly.
          </p>
        </section>

        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">12. Children's Privacy</h2>
          <p class="mb-3">
            Our services are not directed at children under the age of 13. We do not knowingly
            collect personal data from children under 13 without verifiable parental or guardian
            consent. If you believe we have inadvertently collected data from a child, please
            contact us immediately and we will take steps to delete such data.
          </p>
          <p>
            For photography sessions involving minors, we require explicit written consent from a
            parent or legal guardian before the session takes place, and before any images of minors
            are used for any purpose beyond service delivery.
          </p>
        </section>

        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">13. Links to Third-Party Websites</h2>
          <p>
            Our website may contain links to third-party websites. We are not responsible for the
            privacy practices of those websites and encourage you to review their privacy policies
            before providing any personal data.
          </p>
        </section>

        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">14. Changes to This Privacy Policy</h2>
          <p class="mb-3">
            We may update this Privacy Policy from time to time to reflect changes in our practices,
            legal obligations, or for other operational reasons. We will post any updates on our
            website at www.inlexistudio.com with the revised date. We encourage you to review this
            policy periodically.
          </p>
          <p>
            For significant changes that affect how we process your personal data, we will notify
            you directly where we hold your contact information.
          </p>
        </section>

        <section>
          <h2 class="mb-4 font-display text-2xl text-gold">15. Contact Us</h2>
          <p class="mb-4">
            If you have any questions, concerns, or requests regarding this Privacy Policy or our
            data protection practices, please contact us:
          </p>
          <div class="rounded-lg border border-white/10 bg-white/5 p-6 text-gray-300">
            <p class="mb-1 font-display text-lg text-white">In Lexi Studio</p>
            <p class="mb-1">Alex Leszczyński</p>
            <p class="mb-3">2 Haughview Terrace, G5 0LN, Glasgow, Scotland, United Kingdom</p>
            <p class="mb-1">
              Email: <a
                href="mailto:info@inlexistudio.com"
                class="text-gold underline hover:text-white">info@inlexistudio.com</a
              >
            </p>
            <p class="mb-1">
              Phone: <a href="tel:+447966516199" class="text-gold underline hover:text-white"
                >+44 79 6651 6199</a
              >
            </p>
            <p>Website: <span class="text-gold">www.inlexistudio.com</span></p>
          </div>
        </section>
      </div>
    </div>
  </div>
</Layout>
